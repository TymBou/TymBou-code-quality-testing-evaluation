{
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "plugin:security/recommended"
  ],
  "plugins": ["security", "node"],
  "env": {
    "node": true,
    "es2021": true
  },
  "rules": {
    "node/no-missing-import": "error",
    "node/no-unsupported-features/es-syntax": [
      "error",
      { "ignores": ["modules"] }
    ]
  }
}