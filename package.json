{
    "name": "code-quality-testing-evaluation",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "start": "concurrently \"npm run start --workspace=backend\" \"npm run start --workspace=frontend\"",
        "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run start --workspace=frontend\"",
        "test": "npm run test --workspaces --if-present",
        "prepare": "husky install",
        "lint": "npm run lint --workspaces --if-present",
        "test:full": "jest --coverage",
        "prepush-tasks": "npm run test:full && npm run check-coverage",
        "check-coverage": "jest --coverage --coverageThreshold='{ \"global\": { \"branches\": 80, \"functions\": 80, \"lines\": 80, \"statements\": 80 } }'"
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "concurrently": "^8.2.0",
        "eslint": "^8.57.1",
        "eslint-plugin-react": "^7.37.4",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.3.0",
        "prettier": "^3.4.2"
    },
    "lint-staged": {
        "**/*.{js,jsx,ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "**/*.{json,md,css,scss}": [
            "prettier --write"
        ]
    }
}
